@model LearnerOpsLms.Models.EvidenceItem

@{
    ViewData["Title"] = "Archive Evidence";
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-body">
            <h1 class="h3 text-danger">
                Archive Evidence
            </h1>

            <p>
                Confirm that you want to archive:
                <strong>@Model.Title</strong>
            </p>

            <p class="text-muted">
                The evidence record will remain in Azure SQL but will be
                marked as archived.
            </p>

            <form asp-action="Archive"
                  asp-route-id="@Model.Id"
                  method="post">
                <button type="submit" class="btn btn-danger">
                    Confirm archive
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>