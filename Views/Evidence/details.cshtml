@model LearnerOpsLms.Models.EvidenceItem

@{
    ViewData["Title"] = "Evidence Details";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h1 class="h3">@Model.Title</h1>
                    <p class="text-muted mb-0">
                        Evidence record details
                    </p>
                </div>

                @if (Model.IsArchived)
                {
                    <span class="badge bg-secondary">Archived</span>
                }
                else
                {
                    <span class="badge bg-success">Active</span>
                }
            </div>

            <dl class="row">
                <dt class="col-sm-3">Notes</dt>
                <dd class="col-sm-9">@Model.Notes</dd>

                <dt class="col-sm-3">File path</dt>
                <dd class="col-sm-9">
                    <code>@Model.FilePath</code>
                </dd>

                <dt class="col-sm-3">Uploaded</dt>
                <dd class="col-sm-9">
                    @Model.UploadedAt.ToString("dd MMM yyyy HH:mm") UTC
                </dd>
            </dl>

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back to evidence
            </a>
        </div>
    </div>
</div>