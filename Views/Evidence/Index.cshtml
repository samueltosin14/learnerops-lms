@model IEnumerable<LearnerOpsLms.Models.EvidenceItem>

@{
    ViewData["Title"] = "Evidence";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Evidence</h1>
            <p class="text-muted mb-0">
                Manage evidence metadata stored in Azure SQL Database.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            Create evidence
        </a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            No evidence records are currently available.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Notes</th>
                            <th>File path</th>
                            <th>Status</th>
                            <th>Uploaded</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evidenceItem in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@evidenceItem.Title</strong>
                                </td>

                                <td>@evidenceItem.Notes</td>

                                <td>
                                    <code>@evidenceItem.FilePath</code>
                                </td>

                                <td>
                                    @if (evidenceItem.IsArchived)
                                    {
                                        <span class="badge bg-secondary">
                                            Archived
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            Active
                                        </span>
                                    }
                                </td>

                                <td>
                                    @evidenceItem.UploadedAt.ToString("dd MMM yyyy HH:mm")
                                </td>

                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-id="@evidenceItem.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@evidenceItem.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        Edit
                                    </a>

                                    @if (!evidenceItem.IsArchived)
                                    {
                                        <a asp-action="Archive"
                                           asp-route-id="@evidenceItem.Id"
                                           class="btn btn-sm btn-outline-danger">
                                            Archive
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>