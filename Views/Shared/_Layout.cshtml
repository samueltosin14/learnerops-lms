<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - learneropsLms</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/learneropsLms.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand"
               asp-controller="Dashboard"
               asp-action="Index">
                LearnerOps LMS
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link text-light"
                           asp-controller="Dashboard"
                           asp-action="Index">
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light"
                           asp-controller="Courses"
                           asp-action="Index">
                            Courses
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light"
                           asp-controller="Learners"
                           asp-action="Index">
                            Learners
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light"
                           asp-controller="Assessments"
                           asp-action="Index">
                            Assessments
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light"
                           asp-controller="Evidence"
                           asp-action="Index">
                            Evidence
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light"
                           asp-controller="Admin"
                           asp-action="Index">
                            Admin
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-light">
                                @User.Identity.Name
                            </span>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light"
                               asp-area="MicrosoftIdentity"
                               asp-controller="Account"
                               asp-action="SignOut">
                                Sign out
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light"
                               asp-area="MicrosoftIdentity"
                               asp-controller="Account"
                               asp-action="SignIn">
                                Sign in
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - learneropsLms - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
