@model IEnumerable<LearnerOpsLms.Models.Learner>

@{
    ViewData["Title"] = "Learners";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Learners</h1>
            <p class="text-muted mb-0">
                Manage learner records stored in Azure SQL Database.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            Create learner
        </a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            No learners are currently available.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Status</th>
                            <th>Enrolled</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var learner in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@learner.FullName</strong>
                                </td>

                                <td>
                                    <a href="mailto:@learner.Email">
                                        @learner.Email
                                    </a>
                                </td>

                                <td>@learner.Department</td>

                                <td>
                                    @if (learner.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>

                                <td>@learner.EnrolledAt.ToString("dd MMM yyyy")</td>

                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-id="@learner.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@learner.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        Edit
                                    </a>

                                    @if (learner.IsActive)
                                    {
                                        <a asp-action="Deactivate"
                                           asp-route-id="@learner.Id"
                                           class="btn btn-sm btn-outline-danger">
                                            Deactivate
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>