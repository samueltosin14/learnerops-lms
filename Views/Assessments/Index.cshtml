@model IEnumerable<LearnerOpsLms.Models.Assessment>

@{
    ViewData["Title"] = "Assessments";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Assessments</h1>
            <p class="text-muted mb-0">
                Manage assessment records stored in Azure SQL Database.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            Create assessment
        </a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            No assessments are currently available.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Maximum score</th>
                            <th>Pass score</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var assessment in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@assessment.Title</strong>
                                    <div class="small text-muted">
                                        @assessment.Description
                                    </div>
                                </td>

                                <td>@assessment.MaxScore</td>
                                <td>@assessment.PassScore</td>

                                <td>
                                    @if (assessment.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>

                                <td>
                                    @assessment.CreatedAt.ToString("dd MMM yyyy")
                                </td>

                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-id="@assessment.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@assessment.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        Edit
                                    </a>

                                    @if (assessment.IsActive)
                                    {
                                        <a asp-action="Deactivate"
                                           asp-route-id="@assessment.Id"
                                           class="btn btn-sm btn-outline-danger">
                                            Deactivate
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>